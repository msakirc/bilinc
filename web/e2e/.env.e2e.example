# Copy to e2e/.env.e2e (gitignored) to run DB-dependent flows locally.
# Point at the STAGING Supabase project, never paused prod.
NEXT_PUBLIC_SUPABASE_URL=https://<staging-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging-anon-publishable-key>
# Seed user that exists on staging (same as mobile/.maestro/.env SEED_USER).
E2E_USER=e2e_trusted
E2E_PASS=Test1234!
# Low-reputation seed user (<100 pts) for the fact reputation-gate flow.
E2E_LOWREP_USER=e2e_newbie
E2E_LOWREP_PASS=Test1234!
# Admin seed user (user_type = 'admin') for the /yonetim admin-panel flows.
# Does NOT exist by default — seed once with db/seed_e2e_admin.sql, then fill in.
# admin.spec.ts files skip when E2E_ADMIN_USER is unset.
E2E_ADMIN_USER=e2e_admin
E2E_ADMIN_PASS=Test1234!
# Disposable probe users for the write/mutation, gate, and security specs.
# fixture: rep>=100 so it can seed facts; bizowner: user_type=business_owner;
# privesc: a plain consumer used by the self-escalation regression test.
# Create via e2e/seed-probe-users.sh (or the steps in db/seed_e2e_admin.sql).
E2E_FIXTURE_USER=e2e_fixture
E2E_FIXTURE_PASS=Test1234!
E2E_BIZOWNER_USER=e2e_bizowner
E2E_BIZOWNER_PASS=Test1234!
E2E_PRIVESC_USER=e2e_escalation_probe
E2E_PRIVESC_PASS=Test1234!
# Dedicated disposable user id for the admin user-type flip test (its UUID, from
# seed-probe-users.sh output). Never the admin's own id — self-demotion locks it out.
E2E_TYPEFLIP_USER_ID=<e2e_typeflip uuid>
# E2E_ALLOW_WRITE=1    # enable real review/fact submit (writes rows to staging)
# Optional gates:
# E2E_ALLOW_SIGNUP=1   # enable real signup write
# E2E_LIVE_DATA=1      # enable search result-list assertions
