EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Crash reporting (optional). Leave unset to disable Sentry (no-op).
# Get DSN from sentry.io -> your project -> Settings -> Client Keys (DSN).
EXPO_PUBLIC_SENTRY_DSN=
# For sourcemap upload during EAS builds, set these as EAS secrets (not here):
#   SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN

# AWS DynamoDB catalog. Pool grants unauthenticated READ-ONLY on bilinc-catalog.
# Pool id is not secret (ships in app bundle); IAM role enforces read-only scoping.
EXPO_PUBLIC_AWS_REGION=eu-central-1
EXPO_PUBLIC_COGNITO_IDENTITY_POOL_ID=eu-central-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EXPO_PUBLIC_DYNAMODB_TABLE=bilinc-catalog
# Search proxy Lambda Function URL (AWS_IAM auth). Signed client-side with the
# Cognito unauth creds; no Turso URL or token ships in the bundle.
EXPO_PUBLIC_SEARCH_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxx.lambda-url.eu-central-1.on.aws/
