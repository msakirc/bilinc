{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.js"
  },
  "mutate": [
    "src/config/legal.ts",
    "src/services/dynamodb.ts"
  ],
  "coverageAnalysis": "perTest",
  "concurrency": 2,
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 15
  },
  "reporters": ["clear-text", "progress"],
  "timeoutMS": 60000,
  "timeoutFactor": 1.5
}
