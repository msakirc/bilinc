# Copy to .maestro/.env and fill. Pass with: maestro test --env-file .maestro/.env <flow>
# NEVER point these at the prod Supabase project (ref kofxezcajiilsxdekfpt).
# The app under test must be a dev/standalone build whose EXPO_PUBLIC_SUPABASE_URL
# targets a THROWAWAY test project seeded with the rows below.

APP_ID=net.bilinc.app

# Seeded user WITH reputation >= 100 (can submit facts/reviews)
SEED_USER=e2e_trusted
SEED_PASS=Test1234!

# Seeded user WITH reputation < 100 (fact gate must block)
LOWREP_USER=e2e_newbie
LOWREP_PASS=Test1234!

# A search term that returns at least one seeded listing
SEARCH_TERM=Test

# Seeded user for the password-reset flow (09). Seed all 3 security-question
# answers to RESET_ANSWER. Flow 09 stops before changing the password.
RESET_USER=e2e_trusted
RESET_ANSWER=test

# Unique-per-run suffix for register flow (avoids username collision).
# Override on the CLI, e.g. --env REG_SUFFIX=$(date +%s)
REG_SUFFIX=001
